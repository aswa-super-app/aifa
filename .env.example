# Google AI / Gemini API key — required
GOOGLE_API_KEY=your_google_api_key_here

# Google Cloud project (required when using Vertex AI backend)
GOOGLE_CLOUD_PROJECT=your_gcp_project_id_here

# Google Cloud region (optional — defaults to us-central1)
GOOGLE_CLOUD_LOCATION=us-central1

# ADK backend selection: "google_ai" (default) or "vertex_ai"
# GOOGLE_GENAI_USE_VERTEXAI=false
